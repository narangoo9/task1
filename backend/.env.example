NODE_ENV=development
PORT=4000

# Database (Neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/taskflow?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/taskflow?sslmode=require"

# JWT
JWT_ACCESS_SECRET="change-me-to-64-char-random-secret-in-production"
JWT_REFRESH_SECRET="change-me-to-64-char-random-secret-in-production-2"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (Railway / Render)
REDIS_URL="redis://localhost:6379"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Logging
LOG_LEVEL="debug"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
